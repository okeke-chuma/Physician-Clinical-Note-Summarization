#This option helps detect the file type, if it is Word or Text. Modify line 79 based on the location whre you saved the input file.

from transformers import pipeline
from docx import Document
import os

file_path = r"C:\Users\YourName\Documents\Clinical_Note.docx"

# Read file based on extension
extension = os.path.splitext(file_path)[1].lower()

if extension == ".txt":
    with open(file_path, "r", encoding="utf-8") as file:
        clinical_note = file.read()

elif extension == ".docx":
    doc = Document(file_path)
    clinical_note = "\n".join(
        [para.text for para in doc.paragraphs]
    )

else:
    raise ValueError("Only .txt and .docx files are supported")

# Load model
summarizer = pipeline(
    "summarization",
    model="facebook/bart-large-cnn"
)

# Summarize
summary = summarizer(
    clinical_note,
    max_length=200,
    min_length=50,
    do_sample=False
)

print("\n=== CLINICAL NOTE SUMMARY ===\n")
print(summary[0]["summary_text"])


