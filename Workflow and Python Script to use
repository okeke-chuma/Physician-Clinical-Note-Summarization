from transformers import pipeline
from docx import Document

# Path to your Word document
file_path = r"C:\Users\YourName\Documents\Clinical_Note.docx"

# Read Word document
doc = Document(file_path)
clinical_note = "\n".join([para.text for para in doc.paragraphs])

# Load summarization model
summarizer = pipeline(
    "summarization",
    model="facebook/bart-large-cnn"
)

# Generate summary
summary = summarizer(
    clinical_note,
    max_length=200,
    min_length=50,
    do_sample=False
)

print(summary[0]["summary_text"])

